# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
*.egg-info/

# Node (future app/web)
node_modules/
dist/
build/
.next/

# Results / temp
*_results.json
*.log
snapshots/
.coverage
coverage.xml
htmlcov/

# OS
.DS_Store
Thumbs.db

# Secrets material (never commit contents)
.env
*.key
!secrets/example-age-devONLY.age.key
*.pem
.env.local

# DuckDB (future)
*.duckdb
*.duckdb.wal

# Greenfield web bundle builds
app/web/dist/
app/web/.vite/

# Local secrets tree — plaintext drops ignored; SOPS stubs + README are tracked
secrets/*
!secrets/.gitkeep
!secrets/README.md
!secrets/.sops.yaml
!secrets/hub.sops.yaml
!secrets/example-age-devONLY.age.key

# Claude Code — local permission cache + cloned worktrees (may contain secrets; never ship)
.claude/worktrees/
**/.claude/settings.local.json

# Optional local archive mirrors (not part of this repo by default)
archive/

# Cursor IDE — ignore local/cache under .cursor/; keep shared committed rules + agents
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/agents/
!.cursor/agents/**

# Archon — lokale Laufzeitdaten und Secrets
docker/archon/.env
docker/archon/compose.override.yml
docker/archon/Dockerfile.user
docker/archon/data/
docker/archon/user-home/

# Agent OS ephemeral / generated local state
.agent-os/meta-state.json
.agent-os/self-heal/

# Local scratch
.tmp_pr_body.md

# Knowledge — optional local overrides / backups (keep canonical JSON tracked explicitly)
knowledge/*.bak
knowledge/**/*.bak

# Research — PDF binaries / drops never committed (JSON layers + manifests are canonical)
research/incoming/**/*.pdf
research/incoming/**/new download/
research/extracted/**/source.pdf
