# =============================================================================
# Archon — terra-incognita-v2 Environment Template
# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird NICHT ins Git committet.
# =============================================================================

# Telemetry deaktivieren (empfohlen)
DO_NOT_TRACK=1

# Port für Web UI (default: 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Claude (Primärer Orchestrator)
# ---------------------------------------------------------------------------
# Global Auth aus bestehendem `claude /login` nutzen (empfohlen):
CLAUDE_USE_GLOBAL_AUTH=true
# Alternativ: explizite Tokens
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_API_KEY=

# ---------------------------------------------------------------------------
# Pi-Provider (Multi-LLM-Routing inkl. OpenRouter, Gemini, etc.)
# Archon nutzt Pi für alle nicht-Claude-Modelle.
# Tiers: Free (OpenRouter freie Modelle), Smart, Premium
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=       # Falls direkte Anthropic-API gewünscht
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Cursor-Agent-CLI (Phase 5 — Bridge für .cursor/agents)
# ---------------------------------------------------------------------------
# CURSOR_API_KEY=

# ---------------------------------------------------------------------------
# Discord (Phase 3 — Dev-Log, Design-Log, Hauptkonversationen)
# ---------------------------------------------------------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=       # Kommagetrennte User-IDs (Whitelist!)
# DISCORD_STREAMING_MODE=batch

# ---------------------------------------------------------------------------
# Telegram (Phase 6 — Privat, Idea-Capture mit Sonnet-Medium)
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=      # Nur deine User-ID!
# TELEGRAM_STREAMING_MODE=stream

# ---------------------------------------------------------------------------
# Datenbank (optional — default: SQLite)
# Für Postgres: --profile with-db und DATABASE_URL setzen
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/archon
# POSTGRES_PASSWORD=sicher-aendern
